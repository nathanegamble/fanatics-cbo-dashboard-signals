{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fanatics sports events feed",
  "type": "object",
  "required": ["generated_at", "as_of", "status", "warnings", "windows"],
  "properties": {
    "generated_at": {"type": "string"},
    "as_of": {"type": "string"},
    "status": {"enum": ["ok", "partial", "error"]},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "windows": {
      "type": "object",
      "required": ["yesterday", "today", "this_week", "this_month", "next_month"],
      "additionalProperties": {
        "type": "object",
        "required": ["window_start", "window_end", "items"],
        "properties": {
          "window_start": {"type": "string"},
          "window_end": {"type": "string"},
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["headline", "detail", "date", "league", "source_url"],
              "properties": {
                "headline": {"type": "string"},
                "detail": {"type": "string"},
                "date": {"type": "string"},
                "league": {"type": "string"},
                "source_url": {"type": "string"},
                "source_name": {"type": "string"},
                "confidence": {"enum": ["high", "medium", "low"]},
                "relevance": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      }
    }
  }
}
